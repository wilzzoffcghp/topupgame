{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/game/(.*)", "dest": "/public/game.html" },
    { "src": "/order/(.*)", "dest": "/public/order.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/register", "dest": "/public/register.html" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/deposit", "dest": "/public/deposit.html" },
    { "src": "/docs", "dest": "/public/docs.html" },
    { "src": "/reseller", "dest": "/public/reseller.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
